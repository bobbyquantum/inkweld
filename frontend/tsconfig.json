/* To learn more about Typescript configuration file: https://www.typescriptlang.org/docs/handbook/tsconfig-json.html. */
/* To learn more about Angular compiler options: https://angular.dev/reference/configs/angular-compiler-options. */
{
  "compileOnSave": false,
  "compilerOptions": {
    "strict": true,
    "esModuleInterop": true,
    "noImplicitOverride": true,
    "noPropertyAccessFromIndexSignature": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "moduleResolution": "bundler",
    "skipLibCheck": true,
    "isolatedModules": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "ES2022",
    "resolveJsonModule": true,
    "paths": {
      "api-client": ["../packages/inkweld-api-client/src"],
      "@inkweld/prosemirror": ["../packages/inkweld-prosemirror/src/index"],
      "@inkweld/prosemirror/*": ["../packages/inkweld-prosemirror/src/*/index"],
      "@inkweld/presence": ["../packages/inkweld-presence/src/index"],
      "@inkweld/presence/*": ["../packages/inkweld-presence/src/*/index"],
      "@inkweld/api-client": ["../packages/inkweld-api-client/src/index"],
      "@inkweld/api-client/*": ["../packages/inkweld-api-client/src/*"],
      "@inkweld/*": ["../packages/inkweld-api-client/src/*"],
      "@components/*": ["./src/app/components/*"],
      "@dialogs/*": ["./src/app/dialogs/*"],
      "@services/*": ["./src/app/services/*"],
      "@models/*": ["./src/app/models/*"],
      "@editor": ["./src/app/editor/index.ts"],
      "@themes/*": ["./src/themes/*"],
      "@package": ["./package.json"]
    },

    "module": "preserve"
  },
  "angularCompilerOptions": {
    "enableI18nLegacyMessageIdFormat": false,
    "strictInjectionParameters": true,
    "strictInputAccessModifiers": true,
    "typeCheckHostBindings": true,
    "strictTemplates": true
  },
  "files": [],
  "references": [
    {
      "path": "./tsconfig.app.json"
    },
    {
      "path": "./tsconfig.spec.json"
    },
    {
      "path": "./tsconfig.e2e.json"
    }
  ]
}
