{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "./out-tsc/e2e",
    "rootDir": "./e2e",
    "types": ["node", "@playwright/test"],
    "paths": {
      "@inkweld/*": ["./src/api-client/*"],
      "@components/*": ["./src/app/components/*"],
      "@dialogs/*": ["./src/app/dialogs/*"],
      "@services/*": ["./src/app/services/*"],
      "@themes/*": ["./src/themes/*"]
    }
  },
  "include": [
    "e2e/**/*.ts"
  ]
}
