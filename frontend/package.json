{
  "name": "inkweld-frontend",
  "version": "0.1.0",
  "description": "Inkweld - A collaborative creative writing platform for authors, screenwriters, and storytellers",
  "author": "Inkweld <inkweld@example.com>",
  "main": "dist-electron/main.js",
  "scripts": {
    "preinstall": "node -e \"var ua=process.env.npm_config_user_agent||'';if(ua.startsWith('npm/')&&!process.env.INKWELD_BUN_POSTINSTALL){console.error('\\n\\u274c Use bun install, not npm install.\\n   npm creates a package-lock.json that conflicts with bun.lock.\\n   Run from repo root: bun install\\n');process.exit(1)}\"",
    "postinstall": "node scripts/fetch-publish-fonts.mjs && node scripts/copy-changelog.mjs",
    "ng": "ng",
    "start": "ng serve",
    "dev": "ng serve",
    "serve:prod": "ng serve --configuration production",
    "clean": "rimraf dist dist-electron release",
    "build": "ng build",
    "build:cloudflare": "ng build --configuration production && node scripts/compress-wasm.js",
    "generate-icons": "bun scripts/generate-icons.ts",
    "compress-wasm": "node scripts/compress-wasm.js",
    "watch": "ng build --watch --configuration development",
    "test": "ng test --watch=false --no-coverage",
    "test:coverage": "ng test --watch=false",
    "test:watch": "ng test",
    "lint": "ng lint",
    "lint:fix": "ng lint --fix",
    "electron:build": "tsc -p electron/tsconfig.json",
    "electron:serve": "npm run electron:build && electron .",
    "electron:dev": "concurrently -k \"ng serve\" \"wait-on http://localhost:4200 && npm run electron:serve\"",
    "electron:build:angular": "ng build --configuration electron",
    "electron:package": "npm run electron:build:angular && npm run electron:build && electron-builder",
    "electron:package:win": "npm run electron:package -- --win",
    "electron:package:mac": "npm run electron:package -- --mac",
    "electron:package:linux": "npm run electron:package -- --linux",
    "analyze": "ng build --stats-json && esbuild-visualizer --metadata dist/inkweld-frontend/stats.json",
    "upgrade-angular": "ng update @angular/core@22 @angular/cli@22 @angular/material@22 @angular/cdk@22 --allow-dirty",
    "fix-angular-control-flow": "ng generate @angular/core:control-flow",
    "e2e": "npm run e2e:local && npm run e2e:online",
    "e2e:local": "playwright test --config=playwright.local.config.ts",
    "e2e:online": "playwright test --config=playwright.online.config.ts",
    "e2e:local:ui": "playwright test --config=playwright.local.config.ts --ui",
    "e2e:online:ui": "playwright test --config=playwright.online.config.ts --ui",
    "e2e:local:debug": "playwright test --config=playwright.local.config.ts --debug",
    "e2e:online:debug": "playwright test --config=playwright.online.config.ts --debug",
    "e2e:ci": "npm run e2e:local:ci && npm run e2e:online:ci",
    "e2e:local:ci": "playwright test --config=playwright.local.config.ts --reporter=list",
    "e2e:online:ci": "playwright test --config=playwright.online.config.ts --reporter=list",
    "e2e:prod": "ng build && cross-env E2E_MODE=prod npm run e2e:local",
    "e2e:prod:ci": "ng build && cross-env E2E_MODE=prod npm run e2e:local:ci",
    "e2e:screenshots": "playwright test --config=playwright.screenshots.config.ts",
    "e2e:screenshots:ci": "playwright test --config=playwright.screenshots.config.ts --reporter=list",
    "e2e:wrangler": "playwright test --config=playwright.wrangler.config.ts",
    "e2e:wrangler:ui": "playwright test --config=playwright.wrangler.config.ts --ui",
    "e2e:wrangler:debug": "playwright test --config=playwright.wrangler.config.ts --debug",
    "e2e:wrangler:ci": "playwright test --config=playwright.wrangler.config.ts --reporter=list",
    "e2e:cloudflare": "playwright test --config=playwright.cloudflare.config.ts",
    "e2e:cloudflare:ui": "playwright test --config=playwright.cloudflare.config.ts --ui",
    "e2e:docker": "playwright test --config=playwright.docker.config.ts",
    "e2e:docker:ui": "playwright test --config=playwright.docker.config.ts --ui",
    "e2e:docker:debug": "playwright test --config=playwright.docker.config.ts --debug",
    "e2e:docker:ci": "playwright test --config=playwright.docker.config.ts --reporter=list",
    "e2e:mcp": "playwright test --config=playwright.mcp.config.ts",
    "e2e:mcp:ui": "playwright test --config=playwright.mcp.config.ts --ui",
    "e2e:mcp:debug": "playwright test --config=playwright.mcp.config.ts --debug",
    "e2e:mcp:ci": "playwright test --config=playwright.mcp.config.ts --reporter=list",
    "wrangler": "wrangler"
  },
  "private": true,
  "dependencies": {
    "@angular/aria": "^22.0.1",
    "@angular/cdk": "^22.0.1",
    "@angular/common": "^22.0.1",
    "@angular/compiler": "^22.0.1",
    "@angular/core": "^22.0.1",
    "@angular/forms": "^22.0.1",
    "@angular/material": "^22.0.1",
    "@angular/platform-browser": "^22.0.1",
    "@angular/platform-browser-dynamic": "^22.0.1",
    "@angular/router": "^22.0.1",
    "@angular/service-worker": "^22.0.1",
    "@bobbyquantum/ngx-editor": "^22.0.0",
    "@fontsource/courier-prime": "^5.2.8",
    "@fontsource/eb-garamond": "^5.2.7",
    "@fontsource/lato": "^5.2.7",
    "@fontsource/roboto": "5.2.10",
    "@fontsource/source-code-pro": "^5.2.7",
    "@fontsource/source-sans-3": "^5.2.9",
    "@fontsource/source-serif-4": "^5.2.9",
    "@myriaddreamin/typst-ts-renderer": "^0.7.0-rc2",
    "@myriaddreamin/typst-ts-web-compiler": "^0.7.0-rc2",
    "@myriaddreamin/typst.angular": "^0.7.0-rc2",
    "@myriaddreamin/typst.ts": "^0.7.0-rc2",
    "@progress/jszip-esm": "1.0.4",
    "@simplewebauthn/browser": "^13.3.0",
    "angular-split": "20.0.0",
    "cytoscape": "^3.33.1",
    "cytoscape-dagre": "^4.0.0",
    "cytoscape-fcose": "^2.2.0",
    "fracticons": "^1.0.0",
    "konva": "^10.2.0",
    "marked": "^18.0.0",
    "material-icons": "1.13.14",
    "material-symbols": "0.45.5",
    "nanoid": "5.1.15",
    "ngx-image-cropper": "9.1.6",
    "prosemirror-history": "1.5.0",
    "prosemirror-transform": "1.12.0",
    "prosemirror-view": "1.41.9",
    "rxjs": "7.8.2",
    "tslib": "2.8.1",
    "y-indexeddb": "9.0.12",
    "y-prosemirror": "1.3.7",
    "y-websocket": "3.0.0",
    "yjs": "13.6.31"
  },
  "devDependencies": {
    "@angular/build": "^22.0.1",
    "@angular/cli": "^22.0.1",
    "@angular/compiler-cli": "^22.0.1",
    "@eslint/js": "^10.0.0",
    "@playwright/test": "^1.57.0",
    "@types/adm-zip": "^0.5.7",
    "@types/node": "^26.0.0",
    "@vitest/coverage-istanbul": "^4.0.16",
    "@vitest/coverage-v8": "^4.0.16",
    "@vitest/eslint-plugin": "^1.6.5",
    "@vitest/ui": "^4.0.16",
    "adm-zip": "^0.5.16",
    "angular-eslint": "^22.0.0",
    "baseline-browser-mapping": "^2.9.11",
    "concurrently": "^10.0.0",
    "cross-env": "10.1.0",
    "electron": "^42.0.0",
    "electron-builder": "^26.0.12",
    "esbuild": "^0.28.0",
    "esbuild-visualizer": "0.7.0",
    "eslint": "^10.0.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.6",
    "eslint-plugin-simple-import-sort": "13.0.0",
    "eslint-plugin-unused-imports": "4.4.1",
    "fake-indexeddb": "6.2.5",
    "http-server": "^14.1.1",
    "jsdom": "^29.0.0",
    "jszip": "^3.10.1",
    "playwright-ng-schematics": "22.0.1",
    "png-to-ico": "^3.0.1",
    "prettier": "^3.7.4",
    "rimraf": "6.1.3",
    "sharp": "^0.35.0",
    "typescript": "^6.0.0",
    "typescript-eslint": "^8.51.0",
    "vitest": "^4.0.16",
    "vitest-mock-extended": "4.0.0",
    "wait-on": "^9.0.3",
    "wrangler": "^4.54.0"
  },
  "resolutions": {
    "prosemirror-commands": "1.7.1",
    "prosemirror-history": "1.5.0",
    "prosemirror-inputrules": "1.5.1",
    "prosemirror-keymap": "1.2.3",
    "prosemirror-model": "1.25.9",
    "prosemirror-schema-list": "1.5.1",
    "prosemirror-state": "1.4.4",
    "prosemirror-transform": "1.12.0",
    "prosemirror-view": "1.41.9"
  },
  "packageManager": "bun@1.3.13"
}
