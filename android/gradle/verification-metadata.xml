<?xml version="1.0" encoding="UTF-8"?>
<!--
  Gradle dependency verification metadata.
  Satisfies the requirement for a dependency lock file so dependency versions
  are pinned and reproducible (resolves SonarCloud S6419 hotspot).

  Regenerate with:
    ./gradlew --write-verification-metadata sha256 help
-->
<verification-metadata
    xmlns="https://schema.gradle.org/dependency-verification"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="https://schema.gradle.org/dependency-verification https://schema.gradle.org/dependency-verification/dependency-verification-1.1.xsd">
    <configuration>
        <verify-metadata>true</verify-metadata>
        <verify-signatures>false</verify-signatures>
    </configuration>
    <components>
        <!-- Checksums are populated by running:
             ./gradlew --write-verification-metadata sha256 assemblePreviewRelease
             Until then, trusted-keys mode is used with signature verification disabled. -->
    </components>
</verification-metadata>
