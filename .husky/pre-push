#!/bin/sh
# Block direct pushes to main — all changes must go through a PR.
branch=$(git rev-parse --abbrev-ref HEAD)
if [ "$branch" = "main" ]; then
  echo ""
  echo "❌ Direct push to 'main' is not allowed."
  echo ""
  echo "   Create a branch and open a PR instead:"
  echo "     git checkout -b fix/your-change-name"
  echo "     git push -u origin fix/your-change-name"
  echo ""
  echo "   If you need to bypass this for a genuine emergency:"
  echo "     git push --no-verify"
  echo ""
  exit 1
fi

# Validate conventional commit format for all new commits being pushed.
while read local_ref local_oid remote_ref remote_oid; do
  # Skip branch deletions
  [ "$local_oid" = "0000000000000000000000000000000000000000" ] && continue

  if [ "$remote_oid" = "0000000000000000000000000000000000000000" ]; then
    # New branch — lint commits not yet on any remote
    from_flag="--from=HEAD~$(git log --oneline "$local_oid" --not --remotes | wc -l | tr -d ' ')~1"
  else
    from_flag="--from=$remote_oid"
  fi

  npx --no -- commitlint $from_flag --to "$local_oid" || {
    echo ""
    echo "   Fix commit messages or bypass with: git push --no-verify"
    echo ""
    exit 1
  }
done
