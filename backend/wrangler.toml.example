# ========================================
# Inkweld Cloudflare Workers Configuration
# ========================================
#
# QUICK SETUP (from project root):
#   npm run cloudflare:setup
#
# ENVIRONMENTS:
#   - Local dev:   wrangler dev (uses local SQLite, no cloud resources)
#   - Preview:     --env preview (deploys to Cloudflare for testing)
#   - Production:  --env production (live environment)
#
# MANUAL SETUP:
#
# 1. Copy this file:
#    cp wrangler.toml.example wrangler.toml
#
# 2. Login to Cloudflare:
#    npx wrangler login
#
# 3. Create D1 database(s):
#    npx wrangler d1 create inkweld_preview   # Optional
#    npx wrangler d1 create inkweld_prod      # Required for production
#
# 4. Update the database_id values in the env sections below
#
# 5. Set WEBAUTHN_RP_ID to your frontend domain in each [env.*.vars] section.
#    This must match the domain users access the app from. IMMUTABLE after
#    any user registers a passkey — changing it invalidates all credentials.
#
# 6. Set secrets (from backend directory):
#    npx wrangler secret put SESSION_SECRET --env preview
#    npx wrangler secret put SESSION_SECRET --env production
#
# 7. Run migrations (from backend directory):
#    npx wrangler d1 execute inkweld_preview --file=./drizzle/0000_safe_mysterio.sql
#    npx wrangler d1 execute inkweld_prod --file=./drizzle/0000_safe_mysterio.sql
#
# 8. Deploy (from project root):
#    npm run cloudflare:preview:deploy   # Preview
#    npm run cloudflare:prod:deploy      # Production
#
# For more details, see: docs/site/docs/hosting/cloudflare.md
# ========================================

name = "inkweld-backend"
main = "src/cloudflare-runner.ts"
compatibility_date = "2025-01-01"
compatibility_flags = ["nodejs_compat"]

workers_dev = true

[build]
command = ""

# ========================================
# LOCAL DEVELOPMENT (wrangler dev)
# ========================================
# Run with: wrangler dev (from backend directory)
# Uses local SQLite - no Cloudflare resources needed.

[vars]
NODE_ENV = "development"
PORT = "8333"
DB_TYPE = "d1"
ALLOWED_ORIGINS = "http://localhost:4200,http://localhost:4400"
USER_APPROVAL_REQUIRED = "false"
GITHUB_ENABLED = "false"
SESSION_SECRET = "local-dev-session-secret-for-testing-minimum-32-chars"

[[d1_databases]]
binding = "DB"
database_name = "inkweld_local"
database_id = "local"  # Wrangler creates a local SQLite automatically
migrations_dir = "drizzle"

[[durable_objects.bindings]]
name = "YJS_PROJECTS"
class_name = "YjsProject"
script_name = "inkweld-backend"

[[migrations]]
tag = "v1"
new_sqlite_classes = ["YjsProject"]

# ========================================
# PREVIEW ENVIRONMENT (--env preview)
# ========================================
# Deploy with: npm run cloudflare:preview:deploy
# A pre-production environment for testing on real Cloudflare infrastructure.
# Skip this if you only need production.

[env.preview]
name = "inkweld-backend-preview"

# Custom domain for preview backend (optional)
# Uncomment and set your domain. Requires domain to be added to Cloudflare.
# See: https://developers.cloudflare.com/workers/configuration/routing/custom-domains/
# routes = [{ pattern = "api.preview.yourdomain.com", custom_domain = true }]

[env.preview.vars]
NODE_ENV = "preview"
PORT = "8333"
DB_TYPE = "d1"
# Must match your frontend domain (e.g. "preview.inkweld.app").
# IMMUTABLE after any user registers a passkey.
WEBAUTHN_RP_ID = "your-preview-domain.com"
# Include *.your-pages-project.pages.dev to allow deployment preview URLs
ALLOWED_ORIGINS = "http://localhost:4200"
USER_APPROVAL_REQUIRED = "false"
GITHUB_ENABLED = "false"
SESSION_SECRET = "placeholder-set-via-wrangler-secret-put"  # Overridden by secret

# Create with: npx wrangler d1 create inkweld_preview
[[env.preview.d1_databases]]
binding = "DB"
database_name = "inkweld_preview"
database_id = "YOUR_PREVIEW_DATABASE_ID_HERE"  # <-- REPLACE THIS
migrations_dir = "drizzle"

# R2 storage for media files (covers, avatars, inline images)
# Create with: npx wrangler r2 bucket create inkweld-storage-preview
[[env.preview.r2_buckets]]
binding = "STORAGE"
bucket_name = "inkweld-storage-preview"

[[env.preview.durable_objects.bindings]]
name = "YJS_PROJECTS"
class_name = "YjsProject"
script_name = "inkweld-backend-preview"

# ========================================
# PRODUCTION ENVIRONMENT (--env production)
# ========================================
# Deploy with: npm run cloudflare:prod:deploy
# Your live production environment.

[env.production]
name = "inkweld-backend-prod"

# Custom domain for production backend (optional)
# Uncomment and set your domain. Requires domain to be added to Cloudflare.
# See: https://developers.cloudflare.com/workers/configuration/routing/custom-domains/
# routes = [{ pattern = "api.yourdomain.com", custom_domain = true }]

[env.production.vars]
NODE_ENV = "production"
PORT = "8333"
DB_TYPE = "d1"
# Must match your frontend domain (e.g. "app.inkweld.app").
# IMMUTABLE after any user registers a passkey.
WEBAUTHN_RP_ID = "your-production-domain.com"
# Include *.your-pages-project.pages.dev to allow deployment preview URLs
ALLOWED_ORIGINS = ""
USER_APPROVAL_REQUIRED = "true"
GITHUB_ENABLED = "false"
SESSION_SECRET = "placeholder-set-via-wrangler-secret-put"  # Overridden by secret

# Create with: npx wrangler d1 create inkweld_prod
[[env.production.d1_databases]]
binding = "DB"
database_name = "inkweld_prod"
database_id = "YOUR_PROD_DATABASE_ID_HERE"  # <-- REPLACE THIS
migrations_dir = "drizzle"

# R2 storage for media files (covers, avatars, inline images)
# Create with: npx wrangler r2 bucket create inkweld-storage
[[env.production.r2_buckets]]
binding = "STORAGE"
bucket_name = "inkweld-storage"

[[env.production.durable_objects.bindings]]
name = "YJS_PROJECTS"
class_name = "YjsProject"
script_name = "inkweld-backend-prod"

# ========================================
# SECRETS (set via wrangler secret put)
# ========================================
# Secrets are only accessible through c.env (Hono context bindings) at runtime,
# NOT through process.env. The app reads secrets from c.env first, falling back
# to config/process.env for non-Workers environments (Bun/Node.js).
#
# Required for each environment:
#   SESSION_SECRET - Used for JWT signing, CSRF token generation, and session
#                    cookies. Must be at least 32 characters in production.
#   WEBAUTHN_RP_ID - Relying Party ID for WebAuthn/passkey authentication. Must
#                    match your frontend domain (no protocol/port). IMMUTABLE.
#
# Optional:
#   DATABASE_KEY   - Override for SESSION_SECRET, used specifically for database
#                    encryption. Falls back to SESSION_SECRET if not set.
#   GITHUB_CLIENT_ID, GITHUB_CLIENT_SECRET - Required if GitHub OAuth is enabled.
#
# Set with:
#   npx wrangler secret put SESSION_SECRET --env preview
#   npx wrangler secret put SESSION_SECRET --env production
#   npx wrangler secret put DATABASE_KEY --env production  # optional override
